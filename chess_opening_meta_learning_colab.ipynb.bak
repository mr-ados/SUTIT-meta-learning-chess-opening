      ],
      "source": [
        "# Build a few-shot zero-shot evaluation episode from the held-out opening.\n",
        "support_examples, query_examples = build_holdout_episode(\n",
        "    holdout_examples,\n",
        "    support_size=cfg.support_size,\n",
        "    query_size=cfg.query_size,\n",
        ")\n",
        "\n",
        "baseline_results = evaluate_few_shot_baseline(baseline_model, support_examples, query_examples, cfg)\n",
        "maml_results = evaluate_few_shot_maml(maml_model, support_examples, query_examples, cfg)\n",
        "\n",
        "results_df = pd.DataFrame(\n",
        "    [\n",
        "        {\n",
        "            'model': 'Baseline',\n",
        "            'stage': 'Before adaptation',\n",
        "            'top1_accuracy': baseline_results['before_adaptation']['top1_accuracy'],\n",
        "            'cross_entropy_loss': baseline_results['before_adaptation']['loss'],\n",
        "        },\n",
        "        {\n",
        "            'model': 'Baseline',\n",
        "            'stage': 'After adaptation',\n",
        "            'top1_accuracy': baseline_results['after_adaptation']['top1_accuracy'],\n",
        "            'cross_entropy_loss': baseline_results['after_adaptation']['loss'],\n",
        "        },\n",
        "        {\n",
        "            'model': 'MAML',\n",
        "            'stage': 'Before adaptation',\n",
        "            'top1_accuracy': maml_results['before_adaptation']['top1_accuracy'],\n",
        "            'cross_entropy_loss': maml_results['before_adaptation']['loss'],\n",
        "        },\n",
        "        {\n",
        "            'model': 'MAML',\n",
        "            'stage': 'After adaptation',\n",
        "            'top1_accuracy': maml_results['after_adaptation']['top1_accuracy'],\n",
        "            'cross_entropy_loss': maml_results['after_adaptation']['loss'],\n",
        "        },\n",
        "    ]\n",
        ")\n",
        "\n",
        "print('Held-out task:', holdout_task)\n",
        "print('Support example count:', len(support_examples))\n",
        "print('Query example count:', len(query_examples))\n",
        "display(results_df)\n"
      ]
    },
